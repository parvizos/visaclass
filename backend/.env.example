# Environment Variables
NODE_ENV=development
PORT=8084

# Database Configuration (SQLite for development)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=visaclass_booking
DB_PORT=3306

# Email Configuration
# Option 1: Mailtrap (Recommended for development)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_SECURE=false
EMAIL_USER=your-mailtrap-username
EMAIL_PASS=your-mailtrap-password

# Option 2: Ethereal Email (No signup required)
# EMAIL_HOST=smtp.ethereal.email
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-ethereal-user
# EMAIL_PASS=your-ethereal-pass

# Option 3: Gmail (Real emails)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASS=your-app-password

EMAIL_FROM=VISACLASS <noreply@visaclass.com>

# Stripe Configuration (test keys)
STRIPE_SECRET_KEY=sk_test_51234567890abcdef
STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdef
STRIPE_WEBHOOK_SECRET=whsec_51234567890abcdef

# Admin Configuration
ADMIN_EMAIL=admin@visaclass.com

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
CORS_ORIGIN=http://localhost:3000
